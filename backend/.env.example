FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-secret
DATABASE_URL=sqlite:///novelwiki.db
UPLOAD_FOLDER=instance/uploads
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional one-time CLI bootstrap values for:
# flask --app run.py create-superadmin
SUPERADMIN_USERNAME=
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# Render/simple production example:
# FLASK_ENV=production
# DATABASE_URL=sqlite:////var/data/novelwiki.db
# UPLOAD_FOLDER=/var/data/uploads
# FRONTEND_ORIGINS=https://your-frontend.onrender.com
# SESSION_COOKIE_SAMESITE=None
# SESSION_COOKIE_SECURE=true
